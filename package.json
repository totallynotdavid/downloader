{
  "name": "@totallynotdavid/downloader",
  "version": "1.0.2",
  "author": "David Duran <dadch1404@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totallynotdavid/downloader.git"
  },
  "main": "dist/index.js",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "bunup": "^0.16.32",
    "shx": "^0.4.0"
  },
  "bugs": {
    "url": "https://github.com/totallynotdavid/downloader/issues"
  },
  "description": "Get direct download URLs from YouTube, Instagram, TikTok, X, and more.",
  "files": [
    "dist",
    "readme.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/totallynotdavid/downloader#readme",
  "keywords": [
    "imgur",
    "reddit",
    "instagram",
    "facebook",
    "twitter",
    "pinterest",
    "tiktok",
    "downloader"
  ],
  "license": "MIT",
  "scripts": {
    "clean": "bun x shx rm -rf dist",
    "format": "biome format --write . && bun x prettier \"**/*.{md,yml}\" --write --print-width=80 --prose-wrap=always",
    "lint": "biome check .",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit",
    "check": "bun run lint && bun run typecheck",
    "build": "bun run check && bun x bunup",
    "test": "bun test tests/replay",
    "test:update": "bun test tests/replay --update-snapshots",
    "eval": "bun scripts/eval.ts",
    "record": "bun --env-file=.env scripts/record.ts",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "type": "module",
  "types": "dist/index.d.ts"
}
